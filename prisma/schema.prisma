// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas = ["app"]
}

model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  password        String
  name            String?
  role            UserRole  @default(USER)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sessions                Session[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  pushSubscriptions       PushSubscription[]
  eventReminders          EventReminder[]

  @@schema("app")
}

// Comptes et securite

model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])

    @@schema("app")
}

model EmailVerificationToken {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  userId    Int
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])

  @@schema("app")
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  userId    Int
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])

  @@schema("app")
}

// Notifications

model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int?

  user      User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders EventReminder[]
  topics    PushSubscriptionTopic[]
  events    PushEventSubscription[] // Abonnements à des événements spécifiques

  @@index([userId])

  @@schema("app")

}

// Abonnement aux notifications d'événements spécifiques ( utilise slug Strapi )
model PushEventSubscription {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  pushSubscriptionId Int
  pushSubscription   PushSubscription @relation(fields: [pushSubscriptionId], references: [id], onDelete: Cascade)

  eventSlug String // Slug Strapi (ex: "frontex", "dj-solar")
  eventTitle String? // Titre pour affichage
  eventStartsAt DateTime? // Date pour filtrer

  reminders EventSubscriptionReminder[] // Rappels envoyés

  @@unique([pushSubscriptionId, eventSlug]) // Un seul abonnement par event
  @@index([pushSubscriptionId])
  @@index([eventSlug])
  @@index([eventStartsAt])

  @@schema("app")
}

// Rappels envoyés pour les abonnements événements
model EventSubscriptionReminder {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  sentAt    DateTime @default(now())

  pushEventSubscriptionId Int
  pushEventSubscription   PushEventSubscription @relation(fields: [pushEventSubscriptionId], references: [id], onDelete: Cascade)

  @@unique([pushEventSubscriptionId]) // Un seul rappel par abonnement
  @@index([pushEventSubscriptionId])

  @@schema("app")
}

model EventReminder {
  id        Int           @id @default(autoincrement())
  delay     ReminderDelay
  remindAt  DateTime
  sentAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  eventId            Int
  userId             Int?
  pushSubscriptionId Int?
        
  user             User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushSubscription PushSubscription? @relation(fields: [pushSubscriptionId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([userId])
  @@index([pushSubscriptionId])
  @@index([remindAt])

  @@schema("app")

}

// Topics/Sources de notification (ex: General, Urgent, Programme, Benevoles)
model PushTopic {
  id          Int      @id @default(autoincrement())
  key         String   @unique // slug technique: "general", "urgent", "programme"
  label       String   // affichage: "Général", "Urgent", "Programme"
  description String?
  color       String?  // couleur hex pour l'UI: "#ff2d9b"
  isDefault   Boolean  @default(false) // abonnement automatique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions   PushSubscriptionTopic[]
  scheduledPushes ScheduledPush[]

  @@index([isDefault])

  @@schema("app")
}

// Table de jointure: abonnements aux topics
model PushSubscriptionTopic {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  pushSubscriptionId Int
  topicId            Int

  pushSubscription PushSubscription @relation(fields: [pushSubscriptionId], references: [id], onDelete: Cascade)
  topic            PushTopic       @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([pushSubscriptionId, topicId])
  @@index([topicId])

  @@schema("app")
}

// Notifications push programmées à une heure précise
model ScheduledPush {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(120)
  body        String    @db.VarChar(500)
  url         String?   @db.VarChar(500)
  scheduledAt DateTime  // Heure exacte d'envoi
  sentAt      DateTime? // null = pas encore envoyé
  cancelledAt DateTime? // null = pas annulé
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Optionnel : filtrer par topic
  topicId Int?
  topic   PushTopic? @relation(fields: [topicId], references: [id], onDelete: SetNull)

  createdById Int?

  @@index([scheduledAt])
  @@index([sentAt])
  @@index([cancelledAt])
  @@index([topicId])

  @@schema("app")
}

enum UserRole {
  USER
  ADMIN

  @@schema("app")

}

enum ReminderDelay {
  HOURS_24
  HOURS_2
  MINUTES_30

  @@schema("app")

}

